{
  "name": "limitlab-backend",
  "version": "1.0.0",
  "description": "LimitLab backend",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "test:load": "ts-node tests/loadTest.ts",
    "test:load:fw": "ts-node tests/fixedWindowLoadTest.ts",
    "test:load:sw": "ts-node tests/slidingWindowLoadTest.ts",
    "test:load:sl": "ts-node tests/slidingLogLoadTest.ts",
    "test:load:lb": "ts-node tests/leakyBucketLoadTest.ts",
    "test:dl:tb": "node tests/downloadedTestTokenBucket.js",
    "test:dl:fw": "node tests/downloadedTestFixedWindow.js",
    "test:dl:sw": "node tests/downloadedTestSlidingWindow.js",
    "test:dl:sl": "node tests/downloadedTestSlidingLog.js",
    "test:dl:lb": "node tests/downloadedTestLeakyBucket.js"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^6.0.0",
    "@types/pg": "^8.20.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^7.1.0",
    "lru-cache": "^11.5.1",
    "morgan": "^1.10.0",
    "pg": "^8.22.0",
    "pino": "^9.2.0",
    "pino-pretty": "^11.2.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.19.43",
    "@typescript-eslint/eslint-plugin": "^7.15.0",
    "@typescript-eslint/parser": "^7.15.0",
    "axios": "^1.7.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.2",
    "prisma": "^6.0.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.3"
  }
}